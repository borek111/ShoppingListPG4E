<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ShoppingListPG4E.ViewModels"
             xmlns:conv="clr-namespace:ShoppingListPG4E.Converters"
             xmlns:views="clr-namespace:ShoppingListPG4E.Views"
             x:Class="ShoppingListPG4E.Views.AllProductsPage"
             x:DataType="vm:AllProductsViewModel"
             Title="Lista zakupów">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.BindingContext>
        <vm:AllProductsViewModel />
    </ContentPage.BindingContext>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add" Command="{Binding NewCommand}" />
    </ContentPage.ToolbarItems>

    <CollectionView ItemsSource="{Binding Categories}" Margin="10" SelectionMode="None">
        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
        </CollectionView.ItemsLayout>

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="vm:CategoryViewModel">
                <views:CategoryView />
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
