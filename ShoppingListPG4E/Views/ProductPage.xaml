<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:ShoppingListPG4E.ViewModels"
             x:Class="ShoppingListPG4E.Views.ProductPage">

    <!-- Zasób: ViewModel produktu -->
    <ContentPage.Resources>
        <viewModels:ProductViewModel x:Key="Vm"/>
    </ContentPage.Resources>

    <!-- Powiązanie kontekstu z ViewModelem -->
    <ContentPage.BindingContext>
        <StaticResource Key="Vm" />
    </ContentPage.BindingContext>

    <Grid Padding="12" RowSpacing="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*">
        <!-- Pole: nazwa produktu -->
        <Entry Grid.Row="0" Placeholder="Nazwa" Text="{Binding Name, Mode=TwoWay}" />

        <!-- Pole: ilość -->
        <Entry Grid.Row="1" Placeholder="Ilość" Keyboard="Numeric" Text="{Binding Quantity, Mode=TwoWay}" />

        <!-- Pole: jednostka -->
        <Picker Grid.Row="2" Title="Jednostka" ItemsSource="{Binding Units}" SelectedItem="{Binding Unit, Mode=TwoWay}" />

        <!-- Pole: kategoria -->
        <Picker Grid.Row="3" Title="Kategoria" ItemsSource="{Binding Categories}" SelectedItem="{Binding Category, Mode=TwoWay}" />

        <!-- Pole: sklep -->
        <Picker Grid.Row="4" Title="Sklep" ItemsSource="{Binding Stores}" SelectedItem="{Binding Store, Mode=TwoWay}" />

        <!-- Przełącznik: pozycja opcjonalna -->
        <Switch Grid.Row="5" IsToggled="{Binding Optional, Mode=TwoWay}">
            <Switch.Triggers>
                <DataTrigger TargetType="Switch" Binding="{Binding Optional}" Value="True" />
            </Switch.Triggers>
        </Switch>

        <!-- Akcje: Zapisz / Anuluj -->
        <HorizontalStackLayout Grid.Row="6" Spacing="10">
            <Button Text="Zapisz" Command="{Binding AddCommand}" />
            <Button Text="Anuluj" Command="{Binding CancelCommand}" />
        </HorizontalStackLayout>
    </Grid>
</ContentPage>