<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ShoppingListPG4E.Views.ImportAndExportPage"
             Title="Import / Export">
    <VerticalStackLayout Padding="24" Spacing="16">
        <Label Text="Zarządzanie plikiem ShoppingList.xml" FontAttributes="Bold" />
        <Button Text="Exportuj" Command="{Binding ExportCommand}" />
        <Button Text="Importuj" Command="{Binding ImportCommand}" />
        <Label Text="{Binding Status}" TextColor="Gray" LineBreakMode="WordWrap" />
    </VerticalStackLayout>
</ContentPage>